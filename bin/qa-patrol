#!/usr/bin/env bash
set -euo pipefail
# qa-patrol: Controlle QA patrol — runs health checks via the registry.
#
# All checks are defined in the health-check registry (src/health-checks.ts).
# Features register their own health contracts at implementation time.
#
# Usage:
#   bin/qa-patrol                  # Standard checks (quick + tests + nudge)
#   bin/qa-patrol --quick          # Process + config + connectivity only
#   bin/qa-patrol --with-mutation  # Include mutation testing (slow)
#
# Reports failures to the Escalations topic via outbound-cli.
# Exit code: 0 = all checks passed, 1 = one or more checks failed.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

TIER="--standard"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --with-mutation) TIER="--slow"; shift ;;
    --quick)         TIER="--quick"; shift ;;
    -h|--help)
      sed -n '2,/^$/s/^# //p' "$0"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

cd "$REPO_DIR"
exec bun run src/run-health-checks.ts "$TIER"
