#!/usr/bin/env bash
set -euo pipefail
# coverage-gate: Enforce minimum test coverage thresholds for controlle.
#
# Parses bun's lcov coverage output and enforces per-file line coverage:
#   - All files: >= 60% (warn), >= 80% (target)
#   - Changed files (vs base branch): >= 80% (hard gate — blocks submission)
#
# Usage:
#   bin/coverage-gate                  # Check coverage (default base: main)
#   bin/coverage-gate --base=develop   # Custom base branch
#   bin/coverage-gate --warn-only      # Warn but don't block
#   bin/coverage-gate --json           # Machine-readable JSON output
#
# Exit code: 0 = pass, 1 = hard gate failure, 2 = tests failed to run

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

BASE_BRANCH="main"
WARN_ONLY=false
JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base=*)    BASE_BRANCH="${1#--base=}"; shift ;;
    --warn-only) WARN_ONLY=true; shift ;;
    --json)      JSON_OUTPUT=true; shift ;;
    -h|--help)
      sed -n '2,/^$/s/^# //p' "$0"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# --- Thresholds ---
WARN_THRESHOLD=60
GATE_THRESHOLD=80

# --- Helpers ---
out() { [[ "$JSON_OUTPUT" != true ]] && printf '%s\n' "$1" || true; }
outf() { [[ "$JSON_OUTPUT" != true ]] && printf "$@" && printf '\n' || true; }

# --- Step 1: Run tests with coverage ---

COVERAGE_DIR=$(mktemp -d)
trap 'rm -rf "$COVERAGE_DIR"' EXIT

out "[coverage-gate] Running tests with coverage..."

cd "$REPO_DIR"
TEST_OUTPUT=$(bun test --coverage --coverage-reporter=lcov --coverage-dir="$COVERAGE_DIR" 2>&1) || true

LCOV_FILE="${COVERAGE_DIR}/lcov.info"
if [[ ! -f "$LCOV_FILE" ]]; then
  out "  FAIL: Coverage report not generated — tests may have failed to run"
  out ""
  out "Test output:"
  out "$TEST_OUTPUT"
  exit 2
fi

# --- Step 2: Parse lcov for per-file line coverage ---

declare -A FILE_LINES_FOUND
declare -A FILE_LINES_HIT

CURRENT_FILE=""
while IFS= read -r line; do
  case "$line" in
    SF:*)
      CURRENT_FILE="${line#SF:}"
      FILE_LINES_FOUND["$CURRENT_FILE"]=0
      FILE_LINES_HIT["$CURRENT_FILE"]=0
      ;;
    LF:*)
      FILE_LINES_FOUND["$CURRENT_FILE"]="${line#LF:}"
      ;;
    LH:*)
      FILE_LINES_HIT["$CURRENT_FILE"]="${line#LH:}"
      ;;
  esac
done < "$LCOV_FILE"

# --- Step 3: Identify changed files ---

CHANGED_FILES=()
if git rev-parse --verify "${BASE_BRANCH}" &>/dev/null; then
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if [[ "$f" == src/*.ts && "$f" != src/__tests__/* ]]; then
      CHANGED_FILES+=("$f")
    fi
  done < <(git diff --name-only "${BASE_BRANCH}"...HEAD -- 2>/dev/null || true)
fi

# Also include uncommitted changes
for diff_cmd in "git diff --name-only HEAD --" "git diff --name-only --cached --"; do
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if [[ "$f" == src/*.ts && "$f" != src/__tests__/* ]]; then
      already=false
      for existing in "${CHANGED_FILES[@]+"${CHANGED_FILES[@]}"}"; do
        [[ "$existing" == "$f" ]] && already=true
      done
      [[ "$already" != true ]] && CHANGED_FILES+=("$f")
    fi
  done < <($diff_cmd 2>/dev/null || true)
done

# --- Step 4: Evaluate thresholds ---

GATE_FAILURES=()
GATE_WARNINGS=()
ALL_RESULTS=()

out ""
out "[coverage-gate] Per-file line coverage:"
outf "  %-40s  %8s  %5s  %s" "File" "Lines" "Cov%" "Status"
out "  $(printf '%.0s-' {1..76})"

for file in $(echo "${!FILE_LINES_FOUND[@]}" | tr ' ' '\n' | sort); do
  found="${FILE_LINES_FOUND[$file]}"
  hit="${FILE_LINES_HIT[$file]}"

  # Skip test files and setup files
  [[ "$file" == *"__tests__"* ]] && continue

  if [[ "$found" -eq 0 ]]; then
    pct=100
  else
    pct=$(( (hit * 100) / found ))
  fi

  # Is this a changed file?
  is_changed=false
  for cf in "${CHANGED_FILES[@]+"${CHANGED_FILES[@]}"}"; do
    [[ "$cf" == "$file" ]] && is_changed=true
  done

  status="ok"
  if [[ "$is_changed" == true && "$pct" -lt "$GATE_THRESHOLD" ]]; then
    status="GATE FAIL"
    GATE_FAILURES+=("${file}: ${pct}% (changed file, need >=${GATE_THRESHOLD}%)")
  elif [[ "$pct" -lt "$WARN_THRESHOLD" ]]; then
    status="LOW"
    GATE_WARNINGS+=("${file}: ${pct}% (below ${WARN_THRESHOLD}%)")
  elif [[ "$pct" -lt "$GATE_THRESHOLD" ]]; then
    status="warn"
    GATE_WARNINGS+=("${file}: ${pct}% (below target ${GATE_THRESHOLD}%)")
  fi

  marker=""
  [[ "$is_changed" == true ]] && marker=" *"

  outf "  %-40s  %4d/%-4d  %4d%%  %s%s" "$file" "$hit" "$found" "$pct" "$status" "$marker"
  ALL_RESULTS+=("${file}|${hit}|${found}|${pct}|${status}|${is_changed}")
done

# --- Step 5: Check for changed files with NO coverage data (0% effectively) ---

for cf in "${CHANGED_FILES[@]+"${CHANGED_FILES[@]}"}"; do
  if [[ -z "${FILE_LINES_FOUND[$cf]+x}" && -f "$cf" ]]; then
    GATE_FAILURES+=("${cf}: 0% (changed file not covered by any test)")
    outf "  %-40s  %4d/%-4d  %4d%%  %s%s" "$cf" "0" "0" "0" "GATE FAIL" " *"
    ALL_RESULTS+=("${cf}|0|0|0|GATE FAIL|true")
  fi
done

# --- Step 6: Report ---

out ""
if [[ ${#CHANGED_FILES[@]} -gt 0 ]]; then
  out "  (* = changed file, hard gate at ${GATE_THRESHOLD}%)"
fi
out ""

if [[ "$JSON_OUTPUT" == true ]]; then
  items=""
  for entry in "${ALL_RESULTS[@]}"; do
    IFS='|' read -r file hit found pct status changed <<< "$entry"
    [[ -n "$items" ]] && items="${items},"
    items="${items}{\"file\":\"${file}\",\"lines_hit\":${hit},\"lines_found\":${found:-0},\"coverage_pct\":${pct},\"status\":\"${status}\",\"changed\":${changed}}"
  done
  echo "{\"gate_threshold\":${GATE_THRESHOLD},\"warn_threshold\":${WARN_THRESHOLD},\"failures\":${#GATE_FAILURES[@]},\"warnings\":${#GATE_WARNINGS[@]},\"files\":[${items}]}"
fi

if [[ ${#GATE_WARNINGS[@]} -gt 0 ]]; then
  out "[coverage-gate] Warnings (${#GATE_WARNINGS[@]}):"
  for w in "${GATE_WARNINGS[@]}"; do
    out "  WARN: $w"
  done
  out ""
fi

if [[ ${#GATE_FAILURES[@]} -gt 0 ]]; then
  out "[coverage-gate] GATE FAILURES (${#GATE_FAILURES[@]}):"
  for f in "${GATE_FAILURES[@]}"; do
    out "  FAIL: $f"
  done
  out ""
  if [[ "$WARN_ONLY" == true ]]; then
    out "[coverage-gate] --warn-only: not blocking (would have failed)"
    exit 0
  else
    out "[coverage-gate] Changed files must have >= ${GATE_THRESHOLD}% line coverage."
    out "[coverage-gate] Fix coverage gaps or use --warn-only to bypass."
    exit 1
  fi
fi

out "[coverage-gate] All coverage gates passed."
exit 0
